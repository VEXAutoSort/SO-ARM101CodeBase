# ============================================================
# AutoSort machine config — EDIT THIS FOR YOUR MACHINE
# Sourced by every script in scripts/
# ============================================================

# --- USB ports (find with ./scripts/find_ports.sh) ---
# macOS ports look like /dev/tty.usbmodemXXXXXXXX
# Linux ports look like /dev/ttyACM0
FOLLOWER_PORT="/dev/tty.usbmodemCHANGEME1"
LEADER_PORT="/dev/tty.usbmodemCHANGEME2"

# --- Arm IDs (names for calibration files — keep consistent per machine) ---
FOLLOWER_ID="autosort_follower"
LEADER_ID="autosort_leader"

# --- Cameras ---
# index_or_path: 0 is usually the built-in webcam on a Mac; external cams are 1, 2, ...
# Test which index is which before recording!
# Two-camera target setup: one fixed view of the whole workspace + one wrist cam.
# If you only have one camera for now, delete the wrist entry.
CAMERAS='{ top: {type: opencv, index_or_path: 1, width: 640, height: 480, fps: 30}, wrist: {type: opencv, index_or_path: 2, width: 640, height: 480, fps: 30}}'

# --- Recording defaults ---
FPS=30
EPISODE_TIME_S=20      # max seconds per episode (pick one screw + drop = ~10-15s)
RESET_TIME_S=10        # time between episodes to re-scatter screws

# --- Hugging Face ---
# Set after `hf auth login`; datasets push to ${HF_USER}/<dataset_name>
HF_USER="CHANGEME"
