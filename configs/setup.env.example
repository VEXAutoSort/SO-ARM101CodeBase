# ============================================================
# AutoSort machine config — TEMPLATE
# Copy to setup.env and fill in for YOUR machine:
#   cp configs/setup.env.example configs/setup.env
# setup.env is gitignored so real ports never get committed.
# ============================================================

# --- USB ports (find with ./scripts/find_ports.sh) ---
# These change whenever an arm is re-plugged or you switch computers.
# macOS: /dev/tty.usbmodemXXXXXXXX   Linux: /dev/ttyACM0
# Leader = handle arm (5V), Follower = claw arm (12V).
LEADER_PORT="/dev/tty.usbmodemCHANGEME_LEADER"
FOLLOWER_PORT="/dev/tty.usbmodemCHANGEME_FOLLOWER"

# --- Arm IDs (name the calibration files — keep consistent per machine) ---
LEADER_ID="my_leader"
FOLLOWER_ID="my_follower"

# --- Cameras ---
# index_or_path 0 is usually the built-in Mac webcam; external cams are 1, 2, ...
# Add more views by extending the JSON.
CAMERAS='{ top: {type: opencv, index_or_path: 0, width: 960, height: 600, fps: 30}}'

# --- Recording defaults ---
FPS=30
EPISODE_TIME_S=15      # max seconds per episode (one pick + drop ~= 10-15s)
RESET_TIME_S=5         # time between episodes to re-scatter pieces
DEFAULT_TASK="pick up gear and place in container"

# --- Compute + Hugging Face ---
DEVICE=mps             # mps on Apple Silicon, cuda on a GPU box, cpu otherwise
HF_USER="CHANGEME"
